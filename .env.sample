# Copy this file to .env before running, then fill required values.

# Telegram bot token
BOT_TOKEN=

# Database connection (used by bot)
DB_HOST=db
DB_USER=
DB_PASS=
DB_NAME=trisf_assistant

# MySQL container initialization
MYSQL_DATABASE=trisf_assistant
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Telegram superuser ID (required)
SUPERUSER_IDS=

# Bot mode: restricted | open
BOT_MODE=restricted

# Owner contact
OWNER_CONTACT=@trisf
